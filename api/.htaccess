# API .htaccess
Options -Indexes

# =====================================================
# CORS — OBRIGATÓRIO usar domínio específico quando
# credentials: 'include' está ativo no frontend.
# O uso de "*" com credentials é inválido pelo padrão
# CORS e faz o browser rejeitar os cookies de sessão.
# =====================================================
SetEnvIf Origin "^https?://(asl\.erpcondominios\.com\.br|localhost(:[0-9]+)?)$" CORS_ORIGIN=$0

Header always set Access-Control-Allow-Origin "%{CORS_ORIGIN}e" env=CORS_ORIGIN
Header always set Access-Control-Allow-Methods "POST, GET, OPTIONS, PUT, DELETE"
Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, X-API-KEY, X-Bridge-Key, X-Bridge-ID"
Header always set Access-Control-Allow-Credentials "true"
Header always set Vary "Origin"

# Não mostrar erros PHP para o usuário
php_flag display_errors off
php_value error_reporting E_ALL
php_flag log_errors on

# Configurações de sessão PHP — garantir que o cookie
# seja válido para todo o domínio (path=/) e seguro
php_value session.cookie_path /
php_value session.cookie_httponly 1
php_value session.cookie_samesite Lax
php_value session.use_strict_mode 1
php_value session.gc_maxlifetime 7200

# Tratar requisições OPTIONS para CORS preflight
RewriteEngine On
RewriteCond %{REQUEST_METHOD} ^OPTIONS$
RewriteRule ^ - [L,R=200]

# =====================================================
# MOD_SECURITY — Exceções para o Bridge Local
# O Mod_Security bloqueia requisições POST com JSON
# vindo de scripts externos (User-Agent não-browser).
# As regras abaixo desativam as verificações de corpo
# de requisição APENAS para o bridge_receiver.php.
# =====================================================
<Files "bridge_receiver.php">
    # Desativa inspeção de corpo de requisição POST (regras OWASP CRS)
    <IfModule mod_security2.c>
        SecRuleRemoveById 200001
        SecRuleRemoveById 200002
        SecRuleRemoveById 200003
        SecRuleRemoveById 960010
        SecRuleRemoveById 960015
        SecRuleRemoveById 960016
        SecRuleRemoveById 960017
        SecRuleRemoveById 960035
        SecRuleRemoveById 981173
        SecRuleRemoveById 981243
        SecRuleRemoveById 981245
        SecRuleRemoveById 981246
        SecRuleEngine Off
    </IfModule>
</Files>
